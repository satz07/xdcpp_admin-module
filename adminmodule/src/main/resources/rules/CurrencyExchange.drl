rule "Currency Conversion with Percentage with Null marginMaster"
when
    $hm: Map(this["feeMaster"] != "",this["feeMaster"].flatPercFlag.equals("P"), this["marginMaster"]==null)
    $amt: Map(this["currencyAmt"] != "")
then
   FeeMaster fm = (FeeMaster)$hm.get("feeMaster");

   BigDecimal totalAmt = (BigDecimal)$hm.get("currencyAmt");
   BigDecimal baseRate = (BigDecimal)$hm.get("fxBaseRate");
   BigDecimal discountTransactionAmt = totalAmt.multiply(fm.getTransactionFee().divide(new java.math.BigDecimal(100)));
   BigDecimal netAmt = totalAmt.subtract(discountTransactionAmt);
   baseRate = baseRate.setScale(4, RoundingMode.CEILING);

   BigDecimal finalAmt = baseRate.multiply(baseRate);

   System.out.println("Currency Conversion with Percentage with Null marginMaster");

   System.out.println("discountTransactionAmt "+discountTransactionAmt);
   System.out.println("After Transaction Deducted  "+netAmt);
   System.out.println("Total Received Amt  "+finalAmt);
   $hm.put("totalMargin",baseRate);
   $hm.put("totalAmt",finalAmt);
   $hm.put("transactionFee",discountTransactionAmt);

end


rule "Currency Conversion with Flat with Null marginMaster"

when
    $hm: Map(this["feeMaster"] != null,this["feeMaster"].flatPercFlag.equals("F"),this["marginMaster"]==null)
    $amt: Map(this["currencyAmt"] != "")
then
   FeeMaster fm = (FeeMaster)$hm.get("feeMaster");

   BigDecimal totalAmt = (BigDecimal)$hm.get("currencyAmt");
   BigDecimal baseRate = (BigDecimal)$hm.get("fxBaseRate");
   BigDecimal discountTransactionAmt = fm.getTransactionFee();
   BigDecimal netAmt = totalAmt.subtract(discountTransactionAmt);
   baseRate = baseRate.setScale(4, RoundingMode.CEILING);

   BigDecimal finalAmt = netAmt.multiply(baseRate);

   System.out.println("Currency Conversion with Flat with Null marginMaster");

   System.out.println("Flat discountTransactionAmt "+discountTransactionAmt);
   System.out.println("Flat  After Transaction Deducted  "+netAmt);
   System.out.println("Flat Total Received Amt  "+finalAmt);
   $hm.put("totalMargin",baseRate);
   $hm.put("totalAmt",finalAmt);
   $hm.put("transactionFee",discountTransactionAmt);

end
