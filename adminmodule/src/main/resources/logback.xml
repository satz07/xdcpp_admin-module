<?xml version="1.0" encoding="UTF-8"?>
<configuration>
<appender name = "STDOUT" class = "ch.qos.logback.core.ConsoleAppender">
 <encoder>
         <pattern>[%d{yyyy-MM-dd HH:mm:ss}] - %msg%n</pattern>
      </encoder>
</appender>
<appender name="SIZE_TIME_OUTPUT_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <!--WEB3 migration changes - Updated log path for local development (macOS/Windows compatible) -->
    <!-- Use system property LOG_PATH if set, otherwise use ./logs relative to working directory -->
    <file>${LOG_PATH:-logs}/adminremit/adminremit.log</file>
    <encoder>
         <pattern>[%d{yyyy-MM-dd HH:mm:ss}] - %msg%n</pattern>
      </encoder>
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
        <fileNamePattern>${LOG_PATH:-logs}/adminremit/archived/adminremit.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
        <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
			<!--Max Size of file to start Archive -->
            <maxFileSize>50MB</maxFileSize>
        </timeBasedFileNamingAndTriggeringPolicy>

		 <!-- Days till log history to keep -->
         <!-- <maxHistory>3</maxHistory> -->
    </rollingPolicy>
   
</appender>

<logger name="com.adminremit" level="debug" additivity="false">
    <appender-ref ref="SIZE_TIME_OUTPUT_FILE"/>
    <appender-ref ref="STDOUT"/>
</logger>

 <logger name="com.onfido" level="debug" additivity="false">
   <appender-ref ref="SIZE_TIME_OUTPUT_FILE"/>
   <appender-ref ref="STDOUT"/>
 </logger>

 <logger name="org.springframework" level="info" additivity="false">
   <appender-ref ref="SIZE_TIME_OUTPUT_FILE"/>
   <appender-ref ref="STDOUT"/>
 </logger>
   
 <root level = "INFO">
    <appender-ref ref = "SIZE_TIME_OUTPUT_FILE"/>
    <appender-ref ref = "STDOUT"/>
 </root>
 
 <logger name="org.springframework.ws" level="TRACE" additivity="false">
    <appender-ref ref="SIZE_TIME_OUTPUT_FILE"/>
    <appender-ref ref="STDOUT"/>
</logger>

</configuration>