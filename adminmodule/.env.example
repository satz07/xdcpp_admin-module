# Environment variables for admin-module (secrets – do not commit .env)
# 1. Copy this file to .env:   cp .env.example .env
# 2. Replace placeholder values in .env with your real tokens
# 3. Load before running:     export $(grep -v '^#' .env | xargs)
#    Or use your IDE's env file support (e.g. EnvFile plugin)

# Dev / default profile (sandbox)
ONFIDO_SANDBOX_TOKEN=api_sandbox.your_sandbox_token_here

# Prod profile (live)
ONFIDO_LIVE_TOKEN=api_live.your_live_token_here
